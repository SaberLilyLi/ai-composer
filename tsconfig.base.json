{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@company/ai-composer-shared": ["packages/shared/src/index.ts"],
      "@company/ai-composer-providers": ["packages/providers/src/index.ts"],
      "@company/ai-composer-core": ["packages/core/src/index.ts"],
      "@company/ai-composer-vue": ["packages/vue/src/index.ts"],
      "@company/ai-composer": ["packages/react/src/index.ts"]
    }
  }
}
