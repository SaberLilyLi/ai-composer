{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@company/ai-composer": ["../react/dist/index.d.ts"],
      "@company/ai-composer-core": ["../core/dist/index.d.ts"],
      "@company/ai-composer-vue": ["../vue/dist/index.d.ts"],
      "@company/ai-composer-providers": ["../providers/dist/index.d.ts"],
      "@company/ai-composer-shared": ["../shared/src/index.ts"]
    },
    "resolveJsonModule": true,
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
